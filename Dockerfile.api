FROM python:3.10-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PORT=8000
ENV ALLOW_STALE_CACHE=true

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Try to train the model, but don't fail the build if it can't access Binance
RUN python cache_data.py && python train.py || (echo "Training failed, proceeding with cached artifacts if available" && ls -la models/)

EXPOSE 8000

CMD ["python", "api.py"]
